# URL pública do app (sem barra final). Em produção: https://teu-dominio.vercel.app
# Necessário para o redirect do Google OAuth não ir parar ao localhost.
NEXT_PUBLIC_SITE_URL=

# Supabase Public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy fallback accepted by the local helpers if you prefer anon keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Use only in server-side code when a future route needs elevated Supabase access.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails that can be added as workspace members in Settings.
# Valores: emails separados por vírgula (ex: pessoa1@email.com,pessoa2@email.com)
WORKSPACE_MEMBER_ALLOWLIST=

# ── Web Push / VAPID (Sprint 22) ─────────────────────────────────────────────
# Gere um par de chaves com: npx web-push generate-vapid-keys
# A chave pública vai para o browser (NEXT_PUBLIC_); a privada fica só no servidor.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# URI de contato exigido pela spec (mailto: ou https:)
VAPID_SUBJECT=mailto:suporte@financeplanner.app

# ── E2E / Playwright (não usar em produção) ───────────────────────────────────
# Segredo compartilhado entre o global-setup e a rota /api/e2e-auth.
E2E_SECRET=
# Credenciais do usuário de teste criado automaticamente pelo global-setup.
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
